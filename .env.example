VIAM_ADDRESS=your-machine.viam.cloud
VIAM_KEY_ID=your-key-id
VIAM_KEY=your-key
HZ=90
LEFT_ARM=right-arm
LEFT_GRIPPER=right-gripper
RIGHT_ARM=left-arm
RIGHT_GRIPPER=left-gripper
